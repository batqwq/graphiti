# Graphiti MCP Server Environment Configuration

# === Plan A: Google AI Studio direct embedding (current) ===
# google-genai uses this Gemini API endpoint for API-key auth:
# https://generativelanguage.googleapis.com/v1beta/
GOOGLE_API_KEY=
GRAPHITI_EMBEDDING_PROVIDER=gemini
# Preferred requested models were tested first:
# - gemini-embedding-exp-03-07: unavailable for this API key on v1beta
# - text-embedding-004: unavailable for this API key on v1beta
# Current working Google AI Studio model:
GRAPHITI_EMBEDDING_MODEL=gemini-embedding-2
GRAPHITI_EMBEDDING_DIM=1536
GRAPHITI_EMBEDDING_BATCH_SIZE=1
# Optional reranker. Leave empty to avoid extra LLM calls for reranking.
GEMINI_RERANKER_MODEL=

# === Plan B: OpenRouter fallback (enable only after 403 is resolved) ===
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# GRAPHITI_EMBEDDING_PROVIDER=openrouter
# GRAPHITI_EMBEDDING_MODEL=google/gemini-embedding-2-preview

# === LLM extraction configuration ===
# Graphiti still needs an LLM for entity/relation extraction.
LLM_PROVIDER=fireworks
FIREWORKS_API_KEY=
FIREWORKS_API_URL=https://api.fireworks.ai/inference/v1
MODEL_NAME=accounts/fireworks/models/minimax-m2p7
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=4096

# Neo4j Database Configuration
# These settings are used when DATABASE_PROVIDER=neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Local Kuzu Database Configuration
# This avoids requiring Docker, FalkorDB, or Neo4j for a single-machine setup.
DATABASE_PROVIDER=kuzu
KUZU_DB=H:\AI-Memory\graphiti\data\kuzu
KUZU_MAX_CONCURRENT_QUERIES=1

# FalkorDB Database Configuration
FALKORDB_URI=redis://localhost:6379
FALKORDB_PASSWORD=
FALKORDB_DATABASE=default_db

# Optional: Group ID for namespacing graph data
GRAPHITI_GROUP_ID=main

# Concurrency Control
# Controls how many episodes can be processed simultaneously
# Default: 10 (suitable for OpenAI Tier 3, mid-tier Anthropic)
# Adjust based on your LLM provider's rate limits:
#   - OpenAI Tier 1 (free): 1-2
#   - OpenAI Tier 2: 5-8
#   - OpenAI Tier 3: 10-15
#   - OpenAI Tier 4: 20-50
#   - Anthropic default: 5-8
#   - Anthropic high tier: 15-30
#   - Ollama (local): 1-5
# See README.md "Concurrency and LLM Provider 429 Rate Limit Errors" for details
SEMAPHORE_LIMIT=10

# === MCP output limits ===
# Keep tool responses compact for AI clients. Increase only when you explicitly need larger payloads.
MCP_OUTPUT_MAX_RESULTS=20
MCP_OUTPUT_MAX_TEXT_CHARS=1200
MCP_OUTPUT_MAX_ATTRIBUTE_CHARS=800
MCP_OUTPUT_MAX_COLLECTION_ITEMS=20
MCP_OUTPUT_MAX_NESTING_DEPTH=3

# === Remote MCP OAuth protection ===
# Enable this before exposing /mcp/ on the public internet.
# Claude connects through OAuth; keep /health public for uptime checks.
MCP_AUTH_ENABLED=false
MCP_PUBLIC_URL=https://your-domain.example
MCP_AUTH_APPROVAL_PASSWORD=
MCP_AUTH_SCOPES=graphiti:read graphiti:write
# Use /sse when running the MCP server with --transport sse.
MCP_AUTH_RESOURCE_PATH=/mcp
MCP_ALLOWED_HOSTS=
MCP_ALLOWED_ORIGINS=
MCP_AUTH_TOKEN_TTL_SECONDS=2592000

# Optional: Path configuration for Docker
# PATH=/root/.local/bin:${PATH}

# Optional: Memory settings for Neo4j (used in Docker Compose)
# NEO4J_server_memory_heap_initial__size=512m
# NEO4J_server_memory_heap_max__size=1G
# NEO4J_server_memory_pagecache_size=512m

# Azure OpenAI configuration
# Optional: Only needed for Azure OpenAI endpoints
# AZURE_OPENAI_ENDPOINT=your_azure_openai_endpoint_here
# AZURE_OPENAI_API_VERSION=2025-01-01-preview
# AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-gpt-4o-mini-deployment
# AZURE_OPENAI_EMBEDDING_API_VERSION=2023-05-15
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-large-deployment
# AZURE_OPENAI_USE_MANAGED_IDENTITY=false
