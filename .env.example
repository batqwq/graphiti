# === Plan A: Google AI Studio direct embedding (current) ===
# google-genai uses this Gemini API endpoint for API-key auth:
# https://generativelanguage.googleapis.com/v1beta/
GOOGLE_API_KEY=
GRAPHITI_EMBEDDING_PROVIDER=gemini
# Preferred requested models were tested first:
# - gemini-embedding-exp-03-07: unavailable for this API key on v1beta
# - text-embedding-004: unavailable for this API key on v1beta
# Current working Google AI Studio model:
GRAPHITI_EMBEDDING_MODEL=gemini-embedding-2
GRAPHITI_EMBEDDING_DIM=1536
GRAPHITI_EMBEDDING_BATCH_SIZE=1
# Optional reranker. Leave empty to avoid extra LLM calls for reranking.
GEMINI_RERANKER_MODEL=

# === Plan B: OpenRouter fallback (enable only after 403 is resolved) ===
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# GRAPHITI_EMBEDDING_PROVIDER=openrouter
# GRAPHITI_EMBEDDING_MODEL=google/gemini-embedding-2-preview

# === LLM extraction configuration ===
LLM_PROVIDER=fireworks
FIREWORKS_API_KEY=
FIREWORKS_API_URL=https://api.fireworks.ai/inference/v1
MODEL_NAME=accounts/fireworks/models/minimax-m2p7
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=4096

# Neo4j database connection
NEO4J_URI=
NEO4J_PORT=
NEO4J_USER=
NEO4J_PASSWORD=

# Local Kuzu database connection
DATABASE_PROVIDER=kuzu
KUZU_DB=data/kuzu
KUZU_MAX_CONCURRENT_QUERIES=1

# FalkorDB database connection
FALKORDB_URI=redis://localhost:6379
FALKORDB_PORT=
FALKORDB_USER=
FALKORDB_PASSWORD=
FALKORDB_DATABASE=default_db

USE_PARALLEL_RUNTIME=
SEMAPHORE_LIMIT=10

# === MCP output limits ===
# Keep tool responses compact for AI clients. Increase only when you explicitly need larger payloads.
MCP_OUTPUT_MAX_RESULTS=20
MCP_OUTPUT_MAX_TEXT_CHARS=1200
MCP_OUTPUT_MAX_ATTRIBUTE_CHARS=800
MCP_OUTPUT_MAX_COLLECTION_ITEMS=20
MCP_OUTPUT_MAX_NESTING_DEPTH=3

# === Remote MCP OAuth protection ===
# Enable this before exposing /mcp/ on the public internet.
MCP_AUTH_ENABLED=false
MCP_PUBLIC_URL=https://your-domain.example
MCP_AUTH_APPROVAL_PASSWORD=
MCP_AUTH_SCOPES=graphiti:read graphiti:write
# Use /sse when running the MCP server with --transport sse.
MCP_AUTH_RESOURCE_PATH=/mcp
MCP_ALLOWED_HOSTS=
MCP_ALLOWED_ORIGINS=
MCP_AUTH_TOKEN_TTL_SECONDS=2592000

GITHUB_SHA=
MAX_REFLEXION_ITERATIONS=
ANTHROPIC_API_KEY=
